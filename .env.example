# Django settings
DJANGO_SECRET_KEY=your-secret-key-here-change-in-production
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# Database
DB_ENGINE=django.db.backends.postgresql
DB_NAME=inventory_sales
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# Security (set to True in production with HTTPS)
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False

# Session
SESSION_COOKIE_AGE=3600

# Upload limits (bytes)
DATA_UPLOAD_MAX_MEMORY_SIZE=5242880

# CSRF trusted origins for ngrok (comma-separated, no spaces)
# DJANGO_CSRF_NGROK_HTTP=http://your-ngrok-url.ngrok-free.app

# License validation (MUST match KeyManagement LICENSE_SECRET)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
LICENSE_SECRET=
